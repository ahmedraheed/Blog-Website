@model IEnumerable<BlogApp.Models.Post>

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="page-header">
    <h1>⚙️ Admin Dashboard</h1>
    <p class="text-muted mb-0">Manage your blog at a glance</p>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card stat-card bg-primary">
            <div class="card-header">📄 Total Posts</div>
            <div class="card-body">
                <h5>@ViewBag.TotalPosts</h5>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card bg-success">
            <div class="card-header">💬 Total Comments</div>
            <div class="card-body">
                <h5>@ViewBag.TotalComments</h5>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card" style="background: var(--primary);">
            <div class="card-header">👥 Total Users</div>
            <div class="card-body">
                <h5>@ViewBag.TotalUsers</h5>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h4 class="mb-3">📈 Category Statistics</h4>
                <canvas id="categoryChart" style="max-height: 300px;"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h4 class="mb-3">👁️ Post Impressions (Read Count)</h4>
                <canvas id="impressionChart" style="max-height: 300px;"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-8">
        <div class="card h-100">
            <div class="card-body">
                <h4 class="mb-3">⏳ Pending Approval</h4>
                @if(ViewBag.PendingPosts != null && ((IEnumerable<BlogApp.Models.Post>)ViewBag.PendingPosts).Any())
                {
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Author</th>
                                <th>Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var item in (IEnumerable<BlogApp.Models.Post>)ViewBag.PendingPosts)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.Title</td>
                                    <td class="text-muted">@item.Author?.UserName</td>
                                    <td class="text-muted">@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <form asp-controller="Posts" asp-action="Approve" asp-route-id="@item.Id" method="post" style="display:inline;">
                                                <button type="submit" class="btn btn-sm btn-success">✅ Approve</button>
                                            </form>
                                            <a asp-controller="Posts" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">View</a>
                                            <a asp-controller="Posts" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted mb-0">🎉 No pending posts — all caught up!</p>
                }
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header bg-white pb-0 border-0">
                <h4 class="mb-0">🟢 Online Users</h4>
            </div>
            <div class="card-body">
                @if(ViewBag.OnlineUsers != null)
                {
                    var onlineList = (IEnumerable<dynamic>)ViewBag.OnlineUsers;
                    if(onlineList.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach(var user in onlineList)
                            {
                                <li class="list-group-item px-0 d-flex align-items-center">
                                    <span class="badge bg-success rounded-circle p-1 me-2" style="width:10px; height:10px;"> </span>
                                    <div>
                                        <div class="fw-bold">@user.UserName</div>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No users online.</p>
                    }
                }
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">📋 Recent Posts</h4>
            <a asp-controller="Posts" asp-action="Create" class="btn btn-sm btn-primary">✏️ New Post</a>
        </div>
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Author</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.Title</td>
                        <td class="text-muted">@item.Author?.UserName</td>
                        <td class="text-muted">@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td>
                            @if (item.IsApproved)
                            {
                                <span class="badge bg-success">Published</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Pending</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <form asp-controller="Posts" asp-action="ToggleFeature" asp-route-id="@item.Id" method="post" style="display:inline;">
                                    @if (item.IsFeatured)
                                    {
                                        <button type="submit" class="btn btn-sm btn-secondary">⭐ Unfeature</button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-sm btn-outline-warning text-dark">⭐ Feature</button>
                                    }
                                </form>
                                <a asp-controller="Posts" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                                <a asp-controller="Posts" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="mt-3">
            <a asp-controller="Posts" asp-action="Index" class="btn btn-outline-secondary btn-sm">View All Posts →</a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var ctx = document.getElementById('categoryChart').getContext('2d');
            var labels = @Html.Raw(ViewBag.CategoryLabels);
            var data = @Html.Raw(ViewBag.CategoryData);

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Number of Posts',
                        data: data,
                        borderColor: '#0d6efd',
                        backgroundColor: 'rgba(13, 110, 253, 0.1)',
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
                }
            });

            // Impression Chart
            var impCtx = document.getElementById('impressionChart').getContext('2d');
            var impLabels = @Html.Raw(ViewBag.ImpressionLabels);
            var impData = @Html.Raw(ViewBag.ImpressionData);

            new Chart(impCtx, {
                type: 'line',
                data: {
                    labels: impLabels,
                    datasets: [{
                        label: 'Reads',
                        data: impData,
                        borderColor: '#198754',
                        backgroundColor: 'rgba(25, 135, 84, 0.1)',
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
                }
            });
        });
    </script>
}
