@model IEnumerable<BlogApp.Models.Post>

@{
    ViewData["Title"] = "Admin Dashboard";
}

<h1>Admin Dashboard</h1>

<div class="row mt-4">
    <div class="col-md-4">
        <div class="card text-white bg-primary mb-3">
            <div class="card-header">Total Posts</div>
            <div class="card-body">
                <h5 class="card-title">@ViewBag.TotalPosts</h5>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-success mb-3">
            <div class="card-header">Total Comments</div>
            <div class="card-body">
                <h5 class="card-title">@ViewBag.TotalComments</h5>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-info mb-3">
            <div class="card-header">Total Users</div>
            <div class="card-body">
                <h5 class="card-title">@ViewBag.TotalUsers</h5>
            </div>
        </div>
    </div>
</div>

<div class="mt-4">
    <h3>Pending Posts</h3>
    @if(ViewBag.PendingPosts != null && ((IEnumerable<BlogApp.Models.Post>)ViewBag.PendingPosts).Any())
    {
        <table class="table table-striped table-warning">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Author</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var item in (IEnumerable<BlogApp.Models.Post>)ViewBag.PendingPosts)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>@item.Author?.UserName</td>
                        <td>@item.CreatedAt.ToShortDateString()</td>
                        <td>
                            <form asp-controller="Posts" asp-action="Approve" asp-route-id="@item.Id" method="post" style="display:inline;">
                                <button type="submit" class="btn btn-sm btn-success">Approve</button>
                            </form>
                            <a asp-controller="Posts" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">View</a>
                            <a asp-controller="Posts" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No pending posts.</p>
    }
</div>

<div class="mt-4">
    <h3>Recent Posts</h3>
    <a asp-controller="Posts" asp-action="Create" class="btn btn-primary mb-3">Create New Post</a>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Author?.UserName</td>
                    <td>@item.CreatedAt.ToShortDateString()</td>
                    <td>
                        <a asp-controller="Posts" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-controller="Posts" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <a asp-controller="Posts" asp-action="Index" class="btn btn-secondary">View All Posts</a>
</div>
