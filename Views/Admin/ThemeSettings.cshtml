@{
    ViewData["Title"] = "Global Theme Settings";
}

<div class="row mb-4">
    <div class="col-md-8 mx-auto">
        <div class="page-header text-center">
            <h1>🎨 Global Theme Settings</h1>
            <p class="text-muted">Customize the primary color of the entire application for all users.</p>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card shadow-sm">
            <div class="card-body p-5">
                <form asp-action="ThemeSettings" method="post" class="text-center">
                    <label for="primaryColor" class="form-label mb-3 fs-5 fw-bold">Select Primary Color</label>
                    
                    <div class="d-flex justify-content-center mb-4">
                        <input type="color" class="form-control form-control-color" id="primaryColor" name="primaryColor" 
                               value="@ViewBag.CurrentColor" title="Choose your color"
                               style="width: 150px; height: 100px; padding: 0.5rem; cursor: pointer; border-radius: 12px;">
                    </div>
                    
                    <div class="d-grid gap-2 col-md-6 mx-auto">
                        <button type="submit" class="btn btn-primary btn-lg">Apply Theme Globally</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
