<style>
    #aiChatWidget {
        position: fixed;
        bottom: 20px;
        right: 20px;
        width: 350px;
        max-width: calc(100vw - 40px);
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 5px 25px rgba(0,0,0,0.15);
        display: flex;
        flex-direction: column;
        z-index: 1050;
        overflow: hidden;
        transition: transform 0.3s ease-in-out;
    }
    #aiChatWidget.collapsed {
        transform: translateY(calc(100% - 50px));
    }
    #aiChatHeader {
        background: linear-gradient(135deg, #0d6efd, #0dcaf0);
        color: white;
        padding: 12px 15px;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 600;
    }
    #aiChatBody {
        height: 300px;
        overflow-y: auto;
        padding: 15px;
        background: #f8f9fa;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }
    .chat-msg {
        max-width: 85%;
        padding: 10px 14px;
        border-radius: 15px;
        font-size: 0.95rem;
        line-height: 1.4;
    }
    .chat-msg.bot {
        background: #e9ecef;
        color: #212529;
        align-self: flex-start;
        border-bottom-left-radius: 2px;
    }
    .chat-msg.user {
        background: #0d6efd;
        color: #fff;
        align-self: flex-end;
        border-bottom-right-radius: 2px;
    }
    #aiChatFooter {
        padding: 10px;
        background: #fff;
        border-top: 1px solid #dee2e6;
        display: flex;
        gap: 8px;
    }
    #aiChatInput {
        flex: 1;
        border-radius: 20px;
        padding: 8px 15px;
        border: 1px solid #ced4da;
    }
    #aiChatInput:focus {
        outline: none;
        border-color: #0d6efd;
    }
</style>

<div id="aiChatWidget" class="collapsed">
    <div id="aiChatHeader" onclick="toggleChat()">
        <span>🤖 Blog AI Assistant</span>
        <span id="chatToggleIcon">▲</span>
    </div>
    <div id="aiChatBody">
        <div class="chat-msg bot">Hi! I'm the Blog AI Assistant. Ask me any questions about the articles on this site!</div>
    </div>
    <div id="aiChatFooter">
        <input type="text" id="aiChatInput" placeholder="Ask a question..." onkeypress="handleKeyPress(event)" />
        <button class="btn btn-primary btn-sm rounded-circle" style="width: 36px; height: 36px;" onclick="sendAiMessage()">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-send-fill" viewBox="0 0 16 16">
              <path d="M15.964.686a.5.5 0 0 0-.65-.65L.767 5.855H.766l-.452.18a.5.5 0 0 0-.082.887l.41.26.001.002 4.995 3.178 3.178 4.995.002.002.26.41a.5.5 0 0 0 .886-.083l6-15Zm-1.833 1.89L6.637 10.07l-.215-.338a.5.5 0 0 0-.154-.154l-.338-.215 7.494-7.494 1.178-.471-.47 1.178Z"/>
            </svg>
        </button>
    </div>
</div>

<script>
    let _chatHistory = [];

    function toggleChat() {
        const widget = document.getElementById('aiChatWidget');
        const icon = document.getElementById('chatToggleIcon');
        if (widget.classList.contains('collapsed')) {
            widget.classList.remove('collapsed');
            icon.innerText = '▼';
            document.getElementById('aiChatInput').focus();
        } else {
            widget.classList.add('collapsed');
            icon.innerText = '▲';
        }
    }

    function handleKeyPress(e) {
        if (e.key === 'Enter') {
            sendAiMessage();
        }
    }

    async function sendAiMessage() {
        const input = document.getElementById('aiChatInput');
        const text = input.value.trim();
        if (!text) return;

        input.value = '';
        appendMessage('user', text);
        _chatHistory.push({ role: 'user', text: text });
        
        // Show typing indicator
        const typingId = 'typing-' + Date.now();
        appendMessage('bot', '...', typingId);

        try {
            const response = await fetch('/api/bot/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ messages: _chatHistory })
            });

            if (response.ok) {
                const data = await response.json();
                document.getElementById(typingId).innerText = data.text;
                _chatHistory.push({ role: 'bot', text: data.text });
            } else {
                document.getElementById(typingId).innerText = 'Error connecting to AI service.';
            }
        } catch (err) {
            document.getElementById(typingId).innerText = 'Network error occurred.';
        }
    }

    function appendMessage(role, text, id = null) {
        const body = document.getElementById('aiChatBody');
        const msgDiv = document.createElement('div');
        msgDiv.className = `chat-msg ${role}`;
        if (id) msgDiv.id = id;
        msgDiv.innerText = text;
        body.appendChild(msgDiv);
        body.scrollTop = body.scrollHeight;
    }
</script>
