<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="A modern blog platform built with ASP.NET Core" />
    <title>@ViewData["Title"] - BlogApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BlogApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark navbar-custom">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    ✍️ <span>Blog</span>App
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Posts" asp-action="Index">Blog</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Admin" asp-action="Index">
                                    ⚙️ Dashboard
                                </a>
                            </li>
                        }
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Chat" asp-action="Index">
                                    💬 Chat
                                </a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container pb-5">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- AI Chatbot Widget -->
    <partial name="_AIChatWidget" />

    <footer class="border-top footer text-muted mt-auto">
        <div class="container">
            &copy; @DateTime.Now.Year BlogApp — Built with ASP.NET Core
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1050">
          <div id="globalChatToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header bg-primary text-white">
              <strong class="me-auto">New Chat Message</strong>
              <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body">
              <p class="mb-2">You have received a new message.</p>
              <a href="/Chat/Index" class="btn btn-sm btn-outline-primary">Open Chat</a>
            </div>
          </div>
        </div>

        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
        <script>
            // Only initialize the global connection if we are NOT on the Chat page.
            // (The Chat page has its own connection logic to append messages to the UI).
            if (window.location.pathname.toLowerCase().indexOf('/chat') === -1) {
                const globalConnection = new signalR.HubConnectionBuilder()
                    .withUrl("/chatHub")
                    .build();

                globalConnection.on("ReceiveMessage", function (senderId, message) {
                    const toastEl = document.getElementById('globalChatToast');
                    const toast = new bootstrap.Toast(toastEl, { autohide: true, delay: 5000 });
                    toast.show();
                });

                globalConnection.start().catch(function (err) {
                    console.error(err.toString());
                });
            }
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
