@model BlogApp.Models.Post

@{
    ViewData["Title"] = "Delete Post";
}

<div class="page-header">
    <h1>🗑️ Delete Post</h1>
    <p class="text-muted mb-0">This action cannot be undone</p>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card border-danger">
            <div class="card-body">
                <div class="alert alert-danger mb-3">
                    <strong>⚠️ Warning:</strong> Are you sure you want to permanently delete this post?
                </div>
                <dl class="row mb-0">
                    <dt class="col-sm-3">Title</dt>
                    <dd class="col-sm-9 fw-semibold">@Html.DisplayFor(model => model.Title)</dd>
                    <dt class="col-sm-3">Author</dt>
                    <dd class="col-sm-9">@Model.Author?.UserName</dd>
                    <dt class="col-sm-3">Content</dt>
                    <dd class="col-sm-9 text-muted">@(Model.Content.Length > 150 ? Model.Content.Substring(0, 150) + "..." : Model.Content)</dd>
                </dl>
                <hr />
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">🗑️ Delete Permanently</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
