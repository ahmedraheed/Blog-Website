@model IEnumerable<BlogApp.Models.Post>

@{
    ViewData["Title"] = "Blog Posts";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1>📝 Blog Posts</h1>
        <p class="text-muted mb-0">Explore the latest articles from our community</p>
    </div>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-action="Create" class="btn btn-primary">
            ✏️ Write a Post
        </a>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <h4 class="text-muted">No posts yet</h4>
        <p class="text-muted">Be the first to share something!</p>
    </div>
}

<div class="row">
    @foreach (var item in Model) {
        <div class="col-md-12 mb-4">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <h2 class="card-title mb-1">
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark">
                                @Html.DisplayFor(modelItem => item.Title)
                            </a>
                            @if (!item.IsApproved)
                            {
                                <span class="badge bg-warning text-dark">⏳ Pending</span>
                            }
                        </h2>
                    </div>
                    <p class="card-subtitle mb-3">
                        👤 @(item.Author?.UserName ?? "Unknown") &nbsp;·&nbsp; 📅 @item.CreatedAt.ToString("MMM dd, yyyy")
                    </p>
                    <p class="card-text">
                        @(item.Content.Length > 200 ? item.Content.Substring(0, 200) + "..." : item.Content)
                    </p>
                    <div class="d-flex gap-2">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Read More →</a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            @if (!item.IsApproved)
                            {
                                <form asp-action="Approve" asp-route-id="@item.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-success">✅ Approve</button>
                                </form>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>
